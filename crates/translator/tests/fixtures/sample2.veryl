module bar (
    clk: input logic,
    rst: input logic,
    sel: input logic<2>,
    a: input logic<8>,
    b: input logic<8>,
    y: output logic<8>,
) {
    var r: logic<8>;
    always_ff (clk, rst) {
        if_reset {
            r = 8'h00;
        } else {
            case sel {
                2'd0: r = a;
                2'd1: r = b;
                2'd2, 2'd3: r = a + b;
                default: r = 8'hff;
            }
        }
    }

    always_comb {
        if sel == 2'd0 {
            y = r;
        } else {
            y = ~r;
        }
    }

}

