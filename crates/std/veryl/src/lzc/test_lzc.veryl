#[test(test_lzc_128)]
module test_lzc_128 {
    import lzc_pkg::<128>::*;

    var bits  : logic     <128>;
    var result: lzc_result     ;

    initial {
        bits    = '0;
        result  = lzc(bits, true);
        $assert(result.all_zero);

        for i: i32      in 0..128 {
            var exp: logic<7>;

            bits    = '0;
            bits[i] = '1;
            result  = lzc(bits, true);

            exp     = 127 - i;
            $assert(!result.all_zero);
            $assert(result.count == exp);
        }

        $finish();
    }
}
