#[test(test_lzc_4)]
module test_lzc_4 {
    import lzc_pkg::<4>::*;

    var bits  : logic     <4>;
    var result: lzc_result   ;

    initial {
        bits    = '0;
        result  = lzc(bits, true);
        $assert(result.all_zero);

        for i: i32      in 0..4 {
            var exp: logic<2>;

            bits    = '0;
            bits[i] = '1;
            result  = lzc(bits, true);

            exp     = 3 - i;
            $assert(!result.all_zero);
            $assert(result.count == exp);
        }

        $finish();
    }
}

